# Базовый шаблон для локального старта с Docker Compose.
# Если нужен более подробный расклад по доменам, смотрите:
# - ops/env/base.env.example
# - ops/env/bot.env.example
# - ops/env/backend.env.example
# - ops/env/ai.env.example
# - ops/env/attachments.env.example
# - ops/env/security.env.example
# - ops/env/local.env.example

APP__NAME=tg-helpdesk
APP__ENVIRONMENT=dev
APP__DRY_RUN=true

BOT__TOKEN=123:ABC

AUTHORIZATION__SUPER_ADMIN_TELEGRAM_USER_IDS=123456789

DATABASE__HOST=localhost
DATABASE__PORT=5434
DATABASE__USER=helpdesk
DATABASE__PASSWORD=helpdesk
DATABASE__DATABASE=helpdesk

REDIS__HOST=localhost
REDIS__PORT=6381
REDIS__DB=0

BACKEND_SERVICE__HOST=localhost
BACKEND_SERVICE__PORT=50071
BACKEND_AUTH__TOKEN=change-me-in-prod
BACKEND_AUTH__CALLER=telegram-bot

AI_SERVICE__HOST=localhost
AI_SERVICE__PORT=50081
AI_SERVICE_AUTH__TOKEN=change-me-ai-in-prod
AI_SERVICE_AUTH__CALLER=helpdesk-backend

AI__PROVIDER=huggingface
AI__MODEL_ID=Qwen/Qwen3.5-4B
AI__API_TOKEN=hf_xxx
AI__BASE_URL=https://router.huggingface.co/v1/chat/completions
AI__SUMMARY_TEMPERATURE=0.15
AI__SUMMARY_MAX_OUTPUT_TOKENS=320
AI__MACROS_TEMPERATURE=0.2
AI__MACROS_MAX_OUTPUT_TOKENS=280
AI__CATEGORY_TEMPERATURE=0.1
AI__CATEGORY_MAX_OUTPUT_TOKENS=160

LOGGING__LEVEL=INFO
LOGGING__STRUCTURED=true

RESILIENCE__STARTUP_CHECK_TIMEOUT_SECONDS=5
RESILIENCE__STARTUP_RETRY_ATTEMPTS=3
RESILIENCE__GRPC_REQUEST_TIMEOUT_SECONDS=10
RESILIENCE__TELEGRAM_SEND_TIMEOUT_SECONDS=10

ATTACHMENTS__PHOTO_MAX_BYTES=10485760
ATTACHMENTS__DOCUMENT_MAX_BYTES=20971520
ATTACHMENTS__VOICE_MAX_BYTES=10485760
ATTACHMENTS__VIDEO_MAX_BYTES=20971520

EXPORTS__INCLUDE_INTERNAL_NOTES_IN_TICKET_REPORTS=true

ASSETS__PATH=assets
