# Reliora environment template.
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Loading priority in the Python Settings class:
#   1. process environment variables;
#   2. .env.local, when present;
#   3. .env.test, only during pytest runs and only as a lower-priority fallback.
#
# Use the names in this file as the canonical env contract.

# Runtime
APP__NAME=tg-helpdesk
APP__ENVIRONMENT=dev
APP__DRY_RUN=true

# Telegram Bot
TELEGRAM_BOT_TOKEN=replace-me
BOT__USERNAME=

# Backend gRPC
BACKEND_SERVICE__HOST=localhost
BACKEND_SERVICE__PORT=50051
BACKEND_SERVICE__LISTEN_HOST=0.0.0.0
BACKEND_EXPOSE_PORT=50051

# Mini App
MINI_APP__LISTEN_HOST=0.0.0.0
MINI_APP__PORT=8080
# Telegram requires a public HTTPS URL. Localhost, private IPs, and http:// do not work.
MINI_APP__PUBLIC_URL=https://mini-app.example.com
MINI_APP__INIT_DATA_TTL_SECONDS=3600
MINI_APP__AI_RATE_LIMIT_WINDOW_SECONDS=60
MINI_APP__AI_SUMMARY_RATE_LIMIT=3
MINI_APP__AI_REPLY_DRAFT_RATE_LIMIT=5
MINI_APP_EXPOSE_PORT=8080

# AI Service
AI_SERVICE__HOST=localhost
AI_SERVICE__PORT=50061
AI_SERVICE__LISTEN_HOST=0.0.0.0
AI_SERVICE_EXPOSE_PORT=50061
AI_SERVICE_AUTH__TOKEN=replace-me
AI_SERVICE_AUTH__CALLER=helpdesk-backend

AI__MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
AI__LOCAL_MODEL_PATH=
AI__LOCAL_CACHE_DIR=/cache/huggingface
AI__LOCAL_TORCH_CACHE_DIR=/cache/torch
AI__LOCAL_TORCH_KERNEL_CACHE_DIR=/cache/torch_kernels
AI__LOCAL_DEVICE=auto
AI__LOCAL_DTYPE=auto
AI__LOCAL_MAX_INPUT_TOKENS=4096
AI__LOCAL_MAX_CONCURRENT_REQUESTS=1
AI__LOCAL_TOP_P=0.9
AI__LOCAL_REPETITION_PENALTY=1.05
AI__LOCAL_TRUST_REMOTE_CODE=false
AI__SUMMARY_TEMPERATURE=0.2
AI__SUMMARY_MAX_OUTPUT_TOKENS=700
AI__REPLY_DRAFT_TEMPERATURE=0.4
AI__REPLY_DRAFT_MAX_OUTPUT_TOKENS=1000
AI__MACROS_TEMPERATURE=0.2
AI__MACROS_MAX_OUTPUT_TOKENS=280
AI__CATEGORY_TEMPERATURE=0.1
AI__CATEGORY_MAX_OUTPUT_TOKENS=400
AI_RUNTIME_SETTINGS__PATH=assets/ai_settings.json

# Database
# DATABASE_URL wins for local commands. Docker Compose clears it inside containers
# and uses the DATABASE__* parts below so services can reach postgres by service name.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/reliora
DATABASE__HOST=localhost
DATABASE__PORT=5432
DATABASE__USER=user
DATABASE__PASSWORD=password
DATABASE__DATABASE=reliora
DATABASE__ECHO=false
POSTGRES_EXPOSE_PORT=5432

# Redis
# REDIS_URL wins for local commands. Docker Compose clears it inside containers
# and uses REDIS__HOST/REDIS__PORT instead.
REDIS_URL=redis://localhost:6379/0
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__DB=0
REDIS__PASSWORD=
REDIS_EXPOSE_PORT=6379

# Security/Auth
AUTHORIZATION__SUPER_ADMIN_TELEGRAM_USER_IDS=123456789
BACKEND_AUTH__TOKEN=replace-me
BACKEND_AUTH__CALLER=telegram-bot

# Observability
LOGGING__LEVEL=INFO
LOGGING__STRUCTURED=true

# Resilience
RESILIENCE__STARTUP_CHECK_TIMEOUT_SECONDS=5
RESILIENCE__STARTUP_RETRY_ATTEMPTS=3
RESILIENCE__STARTUP_RETRY_BACKOFF_SECONDS=0.5
RESILIENCE__GRPC_CONNECT_TIMEOUT_SECONDS=5
RESILIENCE__GRPC_REQUEST_TIMEOUT_SECONDS=10
RESILIENCE__GRPC_READ_RETRY_ATTEMPTS=2
RESILIENCE__GRPC_RETRY_BACKOFF_SECONDS=0.25
RESILIENCE__TELEGRAM_SEND_TIMEOUT_SECONDS=10
RESILIENCE__TELEGRAM_SEND_ATTEMPTS=3

# Attachments
ATTACHMENTS__PHOTO_MAX_BYTES=10485760
ATTACHMENTS__DOCUMENT_MAX_BYTES=20971520
ATTACHMENTS__VOICE_MAX_BYTES=10485760
ATTACHMENTS__VIDEO_MAX_BYTES=20971520

# Exports
EXPORTS__INCLUDE_INTERNAL_NOTES_IN_TICKET_REPORTS=true

# Assets
ASSETS__PATH=assets
