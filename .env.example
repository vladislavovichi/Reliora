# Базовый шаблон для локального старта с зависимостями из Docker Compose.
# Внутри контейнера сервис `app` переопределяет хосты обратно на `postgres`/`redis`.
# Расширенный пример с Docker-портами и полным набором опций:
# ops/env/local.env.example

APP__NAME=tg-helpdesk
APP__ENVIRONMENT=dev
APP__DRY_RUN=true

BOT__TOKEN=123:ABC

AUTHORIZATION__SUPER_ADMIN_TELEGRAM_USER_IDS=123456789

DATABASE__HOST=localhost
DATABASE__PORT=5434
DATABASE__USER=helpdesk
DATABASE__PASSWORD=helpdesk
DATABASE__DATABASE=helpdesk

REDIS__HOST=localhost
REDIS__PORT=6381
REDIS__DB=0

LOGGING__LEVEL=INFO
LOGGING__STRUCTURED=true
