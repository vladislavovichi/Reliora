# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
!ops/env/
!ops/env/README.md
!ops/env/examples/

# Environment files
# Local env files may contain real Telegram tokens, internal auth tokens, and passwords.
.env
.env.*
!.env.example
# Explicit local patterns kept for readability even though .env.* also matches them.
.env.local
.env.*.local
!.env.test
# ops/env is allowed to keep docs and safe examples, but not real env material.
ops/env/**/*.env
ops/env/**/*.local
!ops/env/**/*.example

# Tooling caches and reports
.mypy_cache/
.pytest_cache/
.ruff_cache/
.hypothesis/
.pyre/
.cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
coverage/

# Packaging
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/
*.whl

# Editors and local workspaces
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store

# Local runtime artifacts
*.log
*.sqlite3
*.db
*.pid
*.tmp
*.bak

# Local Docker data
postgres_data/
redis_data/
models/

# Local tooling
.codex
.benchmarks/

# Assets
/assets/

# Frontend build output (source lives in src/mini_app/frontend/)
src/mini_app/static/

# Node.js
node_modules/
.npm/
